# Which listings source serves the app.
#   mock     – 12 polished fixtures bundled in this repo (best for design preview)
#   dealski  – live Swiss Vans stock feed, with automatic fallback to mock
#   native   – this repo's own fixtures, badged as first-party
LISTINGS_SOURCE=mock

# Optional override for the live feed host (defaults to swissvans.dealski.co.uk)
# DEALSKI_BASE_URL=https://swissvans.dealski.co.uk

# Absolute site URL for canonical/OG tags. On Vercel this is derived
# automatically from VERCEL_URL; set explicitly for production.
# NEXT_PUBLIC_SITE_URL=https://vansales.com
