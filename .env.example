# ─── Listings source ──────────────────────────────────────────────────────────
# mock | dealski | native
LISTINGS_SOURCE=dealski

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── Integrations ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your-32-byte-hex-encryption-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Dealski marketplace feed ─────────────────────────────────────────────────
# Optional: override the live stock feed host
DEALSKI_MARKETPLACE_URL=https://swissvans.dealski.co.uk
DEALSKI_MARKETPLACE_KEY=dk_live_your_marketplace_key_here

# ─── Dealski Events API (visitor tracking) ────────────────────────────────────
# Server-only — NEVER prefix with NEXT_PUBLIC_.
# Must be set in Vercel project settings before event tracking activates.
# Generate a per-tenant API key with scope events:write on the Dealski backend.
DEALSKI_API_URL=https://swissvans.dealski.co.uk
DEALSKI_API_KEY=dk_live_your_events_key_here

# ─── Public vars (safe to expose in browser) ──────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://www.swissvans.co.uk
